{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skills",
  "type": "object",
  "properties": {
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "items"],
        "properties": {
          "category": { "type": "string", "minLength": 1 },
          "items": { "type": "array", "items": { "type": "string" } },
          "visible": { "type": "boolean", "default": true },
          "order": { "type": "number" }
        }
      }
    }
  }
}
